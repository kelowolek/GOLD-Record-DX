<Window x:Class="GoldRecordDX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GOLD DX" Height="80" Width="720" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#0A0A0A" CornerRadius="15" BorderBrush="#FFD700" BorderThickness="2" Margin="5">
        <Grid Margin="10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="85"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="45"/>
                <ColumnDefinition Width="65"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="GOLD DX" Foreground="#FFD700" FontWeight="Bold" FontSize="14"/>
                <TextBlock Text="©by kelowolek" Foreground="#FFD700" FontSize="7" Opacity="0.6"/>
            </StackPanel>

            <ComboBox Grid.Column="1" x:Name="ComboAudio" Height="28" VerticalContentAlignment="Center"
                      Background="#0A0A0A" Foreground="#FFD700" BorderBrush="#FFD700"
                      FontSize="10" Margin="5,0">
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0A0A0A" />
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1A1A1A"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                </ComboBox.Resources>
            </ComboBox>

            <ComboBox Grid.Column="2" x:Name="ComboQuality" Height="28" VerticalContentAlignment="Center"
                      Background="#0A0A0A" Foreground="#FFD700" BorderBrush="#FFD700"
                      FontSize="10" Margin="2,0">
                <ComboBoxItem Content="HQ" IsSelected="True"/>
                <ComboBoxItem Content="ECO"/>
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0A0A0A" />
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1A1A1A"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                </ComboBox.Resources>
            </ComboBox>

            <Button Grid.Column="3" Content="📁" Click="BtnFolder_Click" Width="30" Height="28" 
                    Background="Transparent" Foreground="#FFD700" BorderBrush="#FFD700" Cursor="Hand"/>

            <TextBlock Grid.Column="4" x:Name="TxtTimer" Text="00:00:00" Foreground="White" 
                       FontSize="20" VerticalAlignment="Center" FontFamily="Consolas" HorizontalAlignment="Center"/>

            <Button Grid.Column="5" x:Name="BtnRecord" Content="GRAVAR" Click="BtnRecord_Click"
                    Width="85" Height="32" Background="#C6A126" Foreground="Black" 
                    FontWeight="Bold" FontSize="12" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Grid.Column="6" x:Name="BtnPause" Content="II" Width="32" Height="32" 
                    Background="#0A0A0A" Foreground="#FFD700" BorderBrush="#FFD700" 
                    IsEnabled="False" Click="BtnPause_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="—" Click="BtnMinimize_Click" Background="Transparent" Foreground="#FFD700" FontSize="16" Margin="1,0" BorderBrush="Transparent"/>
                <Button Content="✕" Click="BtnClose_Click" Background="Transparent" Foreground="#FFD700" FontSize="16" Margin="1,0" BorderBrush="Transparent"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>